# Example .env for RegulationMonitoring
# Copy to .env and fill real values before starting the container

# Ollama LLM server (change if running on host or different host/container)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# SMTP / mail settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_SECURE=true
SMTP_AUTH=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_ENABLED=false

# Mail addresses and recipients (comma-separated lists)
MAIL_FROM=noreply@example.com
ADMIN_MAIL_ENABLED=false
ADMIN_RECIPIENTS=admin@example.com
ISG_RECIPIENTS=
IK_RECIPIENTS=
MUHASEBE_RECIPIENTS=
LOJISTIK_RECIPIENTS=
IT_SIBER_RECIPIENTS=
KVKK_RECIPIENTS=
